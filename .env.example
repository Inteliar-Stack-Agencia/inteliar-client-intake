# Copiar a .env.local para desarrollo, y cargar en Vercel para producción.

# Proyecto Supabase reusado: "inteliar-labels" (tabla client_intakes,
# separada por RLS del resto de los datos del producto).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Token simple para acceder a /dashboard?token=... — inventá cualquier
# string largo y random, es la única protección de esa página.
DASHBOARD_TOKEN=

# ── Email (copia de cada formulario completado, vía Resend) ─────────
# Sin esta key, el formulario sigue funcionando igual — solo no se envía
# el mail (no-op silencioso, ver lib/send-intake-email.ts).
RESEND_API_KEY=
# Remitente. Requiere un dominio verificado en Resend, o dejar el default
# de pruebas (onboarding@resend.dev) que solo entrega a la cuenta dueña de la API key.
RESEND_FROM=
# A quién le llega la copia de cada envío. Default: inteliarstack.ia@gmail.com
INTAKE_NOTIFY_EMAIL=
